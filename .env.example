# Copy to .env and fill in a valid key. .env is gitignored (never committed).
# Any OpenAI-compatible provider works; switch DA_VERIFY_PROVIDER accordingly.

DA_VERIFY_PROVIDER=minimax
DA_VERIFY_MODEL=MiniMax-M2.7

# --- MiniMax ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# --- DeepSeek (alternative) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
